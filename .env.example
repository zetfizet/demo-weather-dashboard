# METABASE_SECRET_KEY
# Dari: Metabase Settings → Admin → Embedding → Embed Secret
# JANGAN gunakan secret yang sudah di-share di chat/email!
METABASE_SECRET_KEY=

# METABASE_SITE_URL
# URL Metabase Anda (harus bisa diakses dari internet untuk Vercel)
# Contoh lokal: http://localhost:3000
# Contoh production: https://metabase.domain.com
METABASE_SITE_URL=

# PORT (lokal saja)
PORT=3000

# DASHBOARD_ALLOWLIST
# Daftar ID dashboard yang boleh di-embed (pisah dengan koma)
# Contoh: 2,5,7
DASHBOARD_ALLOWLIST=2

# ALLOWED_ORIGINS
# Origin yang boleh akses endpoint token
# Lokal: http://localhost:3000
# Vercel: https://nama-project.vercel.app
# Production custom domain: https://dashboard.domain.com
ALLOWED_ORIGINS=http://localhost:3000

# RATE LIMITING
TOKEN_RATE_WINDOW_MS=60000
TOKEN_RATE_MAX=30

# TRUST_PROXY
# Vercel: set ke true
# Lokal tanpa proxy: false
TRUST_PROXY=false

# INTERNAL_API_KEY (opsional)
# Kosongkan untuk mode public
# Isi untuk proteksi tambahan (server-to-server only)
INTERNAL_API_KEY=